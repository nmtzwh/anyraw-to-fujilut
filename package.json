{
  "name": "anyraw-to-fujilut",
  "version": "0.1.0",
  "private": true,
  "description": "Convert Sony RAW files to Fujifilm F-Log2 images with 3D LUTs applied",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nmtzwh/anyraw-to-fujilut.git"
  },
  "bugs": {
    "url": "https://github.com/nmtzwh/anyraw-to-fujilut/issues"
  },
  "homepage": "https://github.com/nmtzwh/anyraw-to-fujilut#readme",
  "main": "build/electron/main.js",
  "scripts": {
    "typecheck:main": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.renderer.json",
    "typecheck": "npm run typecheck:main && npm run typecheck:renderer",
    "build:main": "esbuild src/electron/main.ts src/electron/preload.ts src/electron/ipc.ts --bundle --platform=node --outdir=build/electron --external:electron --format=cjs",
    "build:renderer": "esbuild src/app.ts src/color.ts src/lut.ts --bundle --outdir=build --format=iife --sourcemap",
    "build": "npm run build:main && npm run build:renderer",
    "clean": "rm -rf build",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "express": "^5.2.1",
    "parse-cube-lut": "^1.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@playwright/test": "^1.40.0",
    "@types/node": "^25.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.9.3"
  }
}
